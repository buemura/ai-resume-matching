# ===========================================
# API - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.

# --- Database Connection ---
# For local development (DB running via docker compose from root):
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/resume_matching

# --- OpenAI ---
# Required for embeddings (text-embedding-ada-002)
# and skill extraction / PII stripping (gpt-4o-mini).
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here
